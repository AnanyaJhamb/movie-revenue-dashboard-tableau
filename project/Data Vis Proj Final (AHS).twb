      </column>
      <column caption='Rev Actual' datatype='integer' name='[Calculation_1094093253204627462]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1094093253171843077]' />
      </column>
      <column caption='Release Season' datatype='string' name='[Calculation_1094093253494280199]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1094093253171527683] IN (&quot;May&quot;,&quot;June&quot;,&quot;July&quot;) THEN &quot;Summer&quot;&#13;&#10;ELSEIF [Calculation_1094093253171527683] IN (&quot;November&quot;,&quot;December&quot;) THEN &quot;Holiday&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Revenue Metric Trend' datatype='real' name='[Calculation_1094093253498941449]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Average&quot; THEN AVG([Calculation_1094093253171843077])&#13;&#10;WHEN &quot;Median&quot; THEN MEDIAN([Calculation_1094093253171843077])&#13;&#10;END' />
      </column>
      <column caption='Revenue Metric (Selected)' datatype='real' name='[Calculation_1094093253506564109]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN &quot;Average&quot; THEN AVG([Calculation_1094093253171843077])&#13;&#10;WHEN &quot;Median&quot;  THEN MEDIAN([Calculation_1094093253171843077])&#13;&#10;WHEN &quot;Sum&quot;     THEN SUM([Calculation_1094093253171843077])&#13;&#10;END' />
      </column>
      <column caption='Release Year (Numeric)' datatype='integer' name='[Calculation_1094093253522472979]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([release_date])' />
      </column>
      <column caption='Language (full name)' datatype='string' name='[Calculation_1094093253533863957]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [original_language] = &quot;en&quot; THEN &quot;English&quot;&#13;&#10;ELSEIF [original_language] = &quot;fr&quot; THEN &quot;French&quot;&#13;&#10;ELSEIF [original_language] = &quot;es&quot; THEN &quot;Spanish&quot;&#13;&#10;ELSEIF [original_language] = &quot;hi&quot; THEN &quot;Hindi&quot;&#13;&#10;ELSEIF [original_language] = &quot;ja&quot; THEN &quot;Japanese&quot;&#13;&#10;ELSEIF [original_language] = &quot;ko&quot; THEN &quot;Korean&quot;&#13;&#10;ELSEIF [original_language] = &quot;zh&quot; THEN &quot;Chinese&quot;&#13;&#10;ELSEIF [original_language] = &quot;de&quot; THEN &quot;German&quot;&#13;&#10;ELSEIF [original_language] = &quot;it&quot; THEN &quot;Italian&quot;&#13;&#10;ELSEIF [original_language] = &quot;ru&quot; THEN &quot;Russian&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Primary Production Country' datatype='string' name='[Calculation_1094093253540892696]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
        <calculation class='tableau' formula='TRIM(&#13;&#10;    IF CONTAINS([production_countries], &quot;,&quot;)&#13;&#10;    THEN SPLIT([production_countries], &quot;,&quot;, 1)&#13;&#10;    ELSE [production_countries]&#13;&#10;    END&#13;&#10;)' />
      </column>
      <column caption='Movies per country' datatype='integer' name='[Calculation_1094093253545607193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([movie_id])' />
      </column>
      <column caption='Production Type' datatype='string' name='[Calculation_1094093253547974682]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([production_countries], &quot;,&quot;)&#13;&#10;THEN &quot;International Co-production&quot;&#13;&#10;ELSE &quot;Single-country Production&quot;&#13;&#10;END' />
      </column>
      <column caption='Movie Count' datatype='integer' name='[Calculation_282600896038535168]' role='measure' type='quantitative'>
