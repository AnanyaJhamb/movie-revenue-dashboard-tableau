      </column>
      <column caption='Studio Type' datatype='string' name='[Calculation_282600896040484865]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF REGEXP_MATCH(LOWER([production_companies]),&#10;&quot;(disney|warner|universal|paramount|sony|columbia|20th century|fox|mgm)&quot;)&#10;THEN &quot;Major Studio&quot;&#10;ELSE &quot;Independent/Other&quot;&#10;END' />
      </column>
      <column caption='Num Production Companies' datatype='integer' name='[Calculation_282600896075665410]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([production_companies]) OR [production_companies] = &quot;&quot; THEN 0&#10;ELSE 1 + (LEN([production_companies]) - LEN(REPLACE([production_companies], &quot;,&quot;, &quot;&quot;)))&#10;END' />
      </column>
      <column caption='Top N Filter' datatype='boolean' name='[Calculation_282600896083488772]' role='measure' type='nominal'>
