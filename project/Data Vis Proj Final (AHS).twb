            <column caption='# Spoken Languages' datatype='integer' name='[Calculation_282600896090484744]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF ISNULL([spoken_languages]) OR [spoken_languages] = &quot;&quot; THEN 0&#10;ELSE 1 + (LEN([spoken_languages]) - LEN(REPLACE([spoken_languages], &quot;,&quot;, &quot;&quot;)))&#10;END' />
