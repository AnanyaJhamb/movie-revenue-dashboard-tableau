            <column caption='Primary Production Country' datatype='string' name='[Calculation_1094093253540892696]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
              <calculation class='tableau' formula='TRIM(&#13;&#10;    IF CONTAINS([production_countries], &quot;,&quot;)&#13;&#10;    THEN SPLIT([production_countries], &quot;,&quot;, 1)&#13;&#10;    ELSE [production_countries]&#13;&#10;    END&#13;&#10;)' />
